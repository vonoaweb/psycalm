# PsyCalm — Environment Variables
# Copiar a .env y completar con tus credenciales

# Server
PORT=10000
NODE_ENV=production
FRONTEND_URL=https://psycalm.onrender.com

# Supabase (OBLIGATORIO)
# La URL tiene formato: https://<20-caracteres>.supabase.co
# Encontrala en: Supabase Dashboard → Settings → API → Project URL
# El REFERENCE ID son 20 caracteres aleatorios, NO el nombre del proyecto
SUPABASE_URL=https://TU_REFERENCE_ID.supabase.co
SUPABASE_SERVICE_KEY=sb_secret_xxxxxxxx

# Cal.com (OBLIGATORIO)
CALCOM_API_KEY=cal_live_xxxxxxxx
CALCOM_EVENT_TYPE_ID=12345678
CALCOM_USERNAME=tu-usuario

# Stripe (modo test por defecto, cambiar a live cuando tengas pasarela)
STRIPE_SECRET_KEY=sk_test_xxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx

# WhatsApp (deshabilitado por ahora)
WHATSAPP_ENABLED=false
